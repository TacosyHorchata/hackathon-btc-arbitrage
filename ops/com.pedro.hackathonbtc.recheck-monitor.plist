<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.pedro.hackathonbtc.recheck-monitor</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>-u</string>
    <string>/Users/pedrorios/Library/Application Support/hackathon-btc/profit_recheck_monitor.py</string>
    <string>--db</string>
    <string>/Users/pedrorios/Library/Application Support/hackathon-btc/live/profitable_cases.sqlite</string>
    <string>--jsonl</string>
    <string>/Users/pedrorios/Library/Application Support/hackathon-btc/live/profit_rechecks.jsonl</string>
    <string>--interval-sec</string>
    <string>10</string>
    <string>--min-age-sec</string>
    <string>5</string>
    <string>--max-age-sec</string>
    <string>3600</string>
    <string>--limit</string>
    <string>20</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/pedrorios/Library/Application Support/hackathon-btc</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PROFIT_RECHECK_WORKERS</key>
    <string>6</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/pedrorios/Library/Logs/hackathon-btc/profit_recheck_monitor.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/pedrorios/Library/Logs/hackathon-btc/profit_recheck_monitor.err.log</string>
</dict>
</plist>
